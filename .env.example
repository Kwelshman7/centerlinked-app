VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Comma-separated emails that auto-claim super_admin on sign-in (requires supabase/bootstrap-super-admin.sql)
VITE_BOOTSTRAP_SUPER_ADMIN_EMAILS=you@company.com

# Facility image pipeline (server/facility-images/run-batch.mjs)
# SUPABASE_SERVICE_ROLE=your-service-role-key
# OPENAI_API_KEY=sk-...  # optional but recommended for people-free verification
# LOVABLE_SUPABASE_URL=https://your-lovable-project-ref.supabase.co
# LOVABLE_SUPABASE_SERVICE_ROLE=your-service-role-key

# Vercel production (Dashboard → Environment Variables):
# SITE_URL=https://www.centerlinked.com

# Google OAuth (configured in Supabase Dashboard, not in this file):
# 1. Google Cloud Console → OAuth client → Authorized redirect URI:
#    https://your-project-ref.supabase.co/auth/v1/callback
# 2. Supabase → Authentication → Providers → Google → Client ID + Secret
# 3. Supabase → Authentication → URL Configuration:
#    Site URL: http://localhost:8080  (local) or https://www.centerlinked.com (prod)
#    Redirect URLs:
#    http://localhost:8080/auth/callback
#    https://www.centerlinked.com/auth/callback
#    https://centerlinked.com/auth/callback
